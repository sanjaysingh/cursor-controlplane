# Copy to .env and fill in values

CURSOR_API_KEY=
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user ids (numeric). Use @userinfobot / @getidsbot to get yours. Required for access.
TELEGRAM_ALLOWED_USER_IDS=
# Optional: append app + uvicorn logs to this file (UTF-8). Install scripts set this for background services.
# CONTROL_PLANE_LOG_FILE=
# Optional: extend PATH for subprocesses (gh, git, etc). Useful when running as a service with limited PATH.
# PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
