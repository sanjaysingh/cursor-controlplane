# Copy to .env and fill in values

CURSOR_API_KEY=
TELEGRAM_BOT_TOKEN=

# Optional on Windows if auto-discovery fails — prefer .cmd over .ps1 when both exist:
# CURSOR_AGENT_BIN=C:\Users\YourName\AppData\Local\cursor-agent\agent.cmd

# Optional default model (`agent --model`). Session-specific model in the dashboard wins.
# CURSOR_AGENT_MODEL=

# Optional: web dashboard identity for session participants (default web:default). Change when isolating profiles on one server; UI loads this via GET /api/dashboard-config.
# WEB_CHANNEL_KEY=web:default
